// Controlador mínimo para hacer I2C a mano (bitBang)
// para poder usar la pantalla. En teoría puede usarse
// para otros dispositivos, siempre que pueda entrar en
// el código, pero no lo recomiendo. En caso de un ATmega328P,
// esto no choca con el I2C nativo y se puede usar independien-
// temente de esta implementación.

// Sección I2C

#if defined(__AVR_ATtiny85__)

 // En ATtiny85 SDA es PB0 pata 5 y SCL es PB1 pata 6
 #define SDA PB0
 #define SCL PB1
 #define PORT_I2C PORTB
 #define DDR_I2C  DDRB
 #define PIN_I2C  PINB

#else

 // Para Nano/Pro Mini (Usando PB2 y PB3)
 #define SDA 3
 #define SCL 2
 #define PORT_I2C PORTB
 #define DDR_I2C  DDRB
 #define PIN_I2C  PINB

#endif

#define SDA_ALTO() PORT_I2C|=(1<<SDA)
#define SDA_BAJO() PORT_I2C&=~(1<<SDA)
#define SCL_ALTO() PORT_I2C|=(1<<SCL)
#define SCL_BAJO() PORT_I2C&=~(1<<SCL)

// 1 es 1 µs, 4 son 4 µs. 0 = No tiene retardo
#if defined(SIN_CRISTAL)
#define RetardoI2C 0
#else
#define RetardoI2C 1
#endif
#if RetardoI2C!=0
#define I2C_DELAY() __builtin_avr_delay_cycles((RetardoI2C*F_CPU)/1000000UL)
#endif

void i2c_inicio()
{
 DDR_I2C|=(1<<SDA) | (1<<SCL);
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SDA_ALTO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif 
 SCL_ALTO();
}

void i2c_comienzo()
{
 SDA_ALTO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SCL_ALTO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SDA_BAJO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SCL_BAJO();
}

// De paso limpia el bus
void i2c_parar()
{
 SDA_BAJO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SCL_ALTO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SDA_ALTO();
}

byte i2c_escribir(byte b)
{
 for(byte i=0;i<8;i++)
 {
  if(b & 0x80) SDA_ALTO(); else SDA_BAJO();
  #if RetardoI2C!=0
  I2C_DELAY();
  #endif
  SCL_ALTO();  // Pulso alto
  #if RetardoI2C!=0
  I2C_DELAY();
  #endif
  SCL_BAJO();  // Pulso bajo
  #if RetardoI2C!=0
  I2C_DELAY();
  #endif
  b<<=1;
 }

 // LECTURA DEL ACK
 // SDA como entrada para escuchar al esclavo
 DDR_I2C&=~(1<<SDA);
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SCL_ALTO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
    
 // Leo el registro PIN_I2C (0 = ACK, 1 = NACK)
 byte ack=(PIN_I2C & (1<<SDA))?1:0;
 SCL_BAJO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 DDR_I2C|=(1<<SDA); // SDA vuelve a ser salida
 SDA_ALTO();        // Libero SDA
 return ack; 
}

byte i2c_lee(byte ack)
{
 byte b=0;
 DDR_I2C&=~(1<<SDA); // SDA como entrada
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 for(byte i=0;i<8;i++)
 {
  SCL_ALTO();
  #if RetardoI2C!=0
  I2C_DELAY();
  #endif
  b<<=1;
  if(PIN_I2C & (1<<SDA)) b|=1; // Lectura real del bus
  SCL_BAJO();
  #if RetardoI2C!=0
  I2C_DELAY();
  #endif
 }

 // ENVIAR ACK/NACK
 DDR_I2C|=(1<<SDA);   // SDA como salida para responder
 if(ack) SDA_BAJO();  // ACK = 0
 else SDA_ALTO();     // NACK = 1
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SCL_ALTO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SCL_BAJO();
 #if RetardoI2C!=0
 I2C_DELAY();
 #endif
 SDA_ALTO();          // Libero SDA
 return b;
}

byte i2c_leoMuchos(byte dir, byte cant, byte *dato)
{
 if(cant==0 || dato==nullptr) return 0;

 // Condición de inicio
 i2c_comienzo();
    
 // Dirección + Bit de Lectura (1)
 // Nota: i2c_escribir debe manejar el ACK del esclavo internamente
 i2c_escribir((dir<<1) | 0x01);

 // Lectura de ráfaga
 for(byte i=0;i<cant;i++)
 {
  // Si no es el último byte, envía ACK (1).
  // Si es el último, envía NACK (0) para finalizar la lectura.
  byte enviarAck=(i<(cant-1))?1:0;
  dato[i]=i2c_lee(enviarAck);
 }
 // Condición de parada
 i2c_parar();
 return cant;
}

// Sección Pantalla OLED

// Para optimizar FLASH:
// FUENTE_MAX==0xFF Todos
// FUENTE_MAX==0x7F Hasta 127
// FUENTE_MAX==0x5F Hasta '_'
// FUENTE_MAX==0x5A Hasta 'Z'
#define FUENTE_MAX 0x5A

#define PANTALLA_ADDR 0x3C

byte cursorX=0;
byte cursorY=0;
bool girada=false;

extern const byte Tipografia5x7[] PROGMEM;

void pantalla_cmd(byte c)
{
 i2c_parar();         // Esencial para cerrar aperturas previas
 i2c_comienzo();
 i2c_escribir(PANTALLA_ADDR<<1);
 i2c_escribir(0x00);
 i2c_escribir(c);
 i2c_parar();
}

void pantalla_comienzoDatos()
{
 i2c_comienzo();
 i2c_escribir(PANTALLA_ADDR<<1);
 i2c_escribir(0x40);
}

void pantalla_posicionar(byte x, byte pag)
{
 // Si sospecho que el bus quedó abierto, i2c_parar() aquí
 // es un salvavidas
 i2c_parar(); 
 #if OLED<=4
 if(!girada) pantalla_cmd(0xB0 | (pag+4));  // Por si invierto pantalla
 else pantalla_cmd(0xB0 | pag);
 #else
 pantalla_cmd(0xB0 | pag);
 #endif
 pantalla_cmd(0x00 | (x & 0x0F));
 pantalla_cmd(0x10 | (x >> 4));
}

void pantalla_comienzo()
{
 i2c_inicio();
 pantalla_cmd(0xAE); // Apagado
 pantalla_cmd(0xD5);
 pantalla_cmd(0x80);
 pantalla_cmd(0xA8);
 pantalla_cmd(0x3F);
 pantalla_cmd(0xD3);
 pantalla_cmd(0x00);
 pantalla_cmd(0x40);
 pantalla_cmd(0x8D);
 pantalla_cmd(0x14);
 pantalla_cmd(0x20);
 pantalla_cmd(0x00);
 pantalla_cmd(0xA1);
 pantalla_cmd(0xC8);
 pantalla_cmd(0xDA);

 #if OLED<=4
 pantalla_cmd(0x02);
 #else
 pantalla_cmd(0x12);
 #endif

 pantalla_cmd(0x81);
 pantalla_cmd(0x7F);
 pantalla_cmd(0xD9);
 pantalla_cmd(0xF1);
 pantalla_cmd(0xDB);
 pantalla_cmd(0x40);
 pantalla_cmd(0xA4);
 pantalla_cmd(0xA6);
 pantalla_cmd(0xAF);
}

void pantalla_encendida()
{
 pantalla_cmd(0xAF);
}

// No la uso
void pantalla_apagada()
{
 pantalla_cmd(0xAE);
}

void pantalla_cursor(byte x, byte y)
{
 cursorX=x;
 cursorY=y;
 pantalla_posicionar(x,y);
}

void pantalla_limpia()
{
 for(byte pag=0;pag<8;pag++)
 {
  pantalla_posicionar(0,pag);
  pantalla_comienzoDatos();
  for(byte i=0;i<128;i++) i2c_escribir(0x00);
  i2c_parar();
 }
 pantalla_cursor(0,0);
}

void pantalla_limpiaPagina(byte pag)
{
 pantalla_cmd(0xB0 | pag);
 pantalla_cmd(0x00);
 pantalla_cmd(0x10);
 pantalla_comienzoDatos();
 for(byte i=0;i<128;i++) i2c_escribir(0);
 i2c_parar();
}

byte tipografia=0;

void pantalla_modoTipo(byte m)
{
 tipografia=m;
}

byte espaciado=1;

void pantalla_separacion(byte s)
{
 espaciado=s;
}

const byte expand2[16] PROGMEM =
{
0x00,0x03,0x0C,0x0F,
0x30,0x33,0x3C,0x3F,
0xC0,0xC3,0xCC,0xCF,
0xF0,0xF3,0xFC,0xFF
};

void pantalla_car(char c)
{
 // FUENTE_MAX==0xFF Todos
 // FUENTE_MAX==0x7F Hasta 127
 // FUENTE_MAX==0x5F Hasta '_'
 // FUENTE_MAX==0x5A Hasta 'Z'

 #if FUENTE_MAX<=0x5F
 // Las minúsculas las paso a mayúsculas cuando hay poca flash
 if(c>='a' && c<='z') c-=0x20;
 #endif

 unsigned long int ind=(c-32)*5;

 if(tipografia==0)
 {
  for(byte i=0;i<5;i++)
  {
   byte col=pgm_read_byte(&Tipografia5x7[ind+i]);
   i2c_escribir(col);
  }
  for(byte i=0;i<espaciado;i++) i2c_escribir(0);
  cursorX+=5+espaciado;
 }
 else
 if(tipografia==1)
 {
  for(byte i=0;i<5;i++)
  {
   byte col=pgm_read_byte(&Tipografia5x7[ind+i]);
   i2c_escribir(col);
   i2c_escribir(col);
  }
  for(byte i=0;i<espaciado*2;i++) i2c_escribir(0);
  cursorX+=10+espaciado*2;
 }
 else   // Tipografía 2
 {
  byte arriba[16];
  byte abajo[16];
  byte k=0;
  for(byte i=0;i<5;i++)
  {
   byte col=pgm_read_byte(&Tipografia5x7[ind+i]);
   byte t=pgm_read_byte(&expand2[col&0x0F]);
   byte b=pgm_read_byte(&expand2[col>>4]);

   arriba[k]=t;
   arriba[k+1]=t;
   abajo[k]=b;
   abajo[k+1]=b;
   k+=2;
  }
  for(byte i=0;i<espaciado;i++)
  {
   arriba[k]=0;
   abajo[k]=0;
   k++;
  }
  pantalla_posicionar(cursorX,cursorY);
  pantalla_comienzoDatos();
  for(byte i=0;i<k;i++) i2c_escribir(arriba[i]);
  i2c_parar();
  pantalla_posicionar(cursorX,cursorY+1);
  pantalla_comienzoDatos();
  for(byte i=0;i<k;i++) i2c_escribir(abajo[i]);
  i2c_parar();
  cursorX += k;
 }
}

void pantalla_printNumeroBase(unsigned long int n)
{
 if(n>=10) pantalla_printNumeroBase(n/10);
 pantalla_print((char)('0'+(n%10)));
}

void pantalla_printNumero(unsigned long int n)
{
 pantalla_printNumeroBase(n);
}

void pantalla_printlnNumero(unsigned long int n)
{
 pantalla_printNumeroBase(n);
 pantalla_linea();
}

void pantalla_printConSigno(long n)
{
 if(n<0)
 {
  pantalla_print('-');
  n=-n;
 }
 pantalla_printNumero((unsigned long int)n);
}

void pantalla_printlnConSigno(long n)
{
 if(n<0)
 {
  pantalla_print('-');
  n=-n;
 }
 pantalla_printlnNumero((unsigned long int)n);
}

void pantalla_print(byte n)
{
 pantalla_printNumero(n);
}

void pantalla_print(int n)
{
 pantalla_printConSigno(n);
}

void pantalla_print(unsigned int n)
{
 pantalla_printNumero(n);
}

void pantalla_print(long n)
{
 pantalla_printConSigno(n);
}

void pantalla_print(unsigned long n)
{
 pantalla_printNumero(n);
}

void pantalla_println(byte n)
{
 pantalla_printlnNumero(n);
}

void pantalla_println(int n)
{
 pantalla_printlnConSigno(n);
}

void pantalla_println(unsigned int n)
{
 pantalla_printlnNumero(n);
}

void pantalla_println(long n)
{
 pantalla_printlnConSigno(n);
}

void pantalla_println(unsigned long n)
{
 pantalla_printlnNumero(n);
}

void pantalla_print(char c)
{
 pantalla_comienzoDatos();
 pantalla_car(c);
 i2c_parar();
}

void pantalla_linea()
{
 byte altura=(tipografia==2)?2:1;
 cursorY=cursorY+altura;
 cursorX=0;
 pantalla_posicionar(0,cursorY);
}

void pantalla_print(const char *s)
{
 pantalla_comienzoDatos();
 while(*s)
 {
  char c=*s++;
  if(c=='\n')
  {
   i2c_parar();
   pantalla_linea();
   pantalla_comienzoDatos();
   continue;
  }
  pantalla_car(c);
 }
 i2c_parar();
}

void pantalla_println(const char *s)
{
 pantalla_print(s);
 if(tipografia==2) cursorY+=2; else cursorY++;
 cursorX=0;
 pantalla_posicionar(cursorX,cursorY);
}

void pantalla_print(const __FlashStringHelper *algo)
{
 PGM_P p=(PGM_P)algo;
 pantalla_comienzoDatos();
 while(true)
 {
  char c=pgm_read_byte(p++);
  if(!c) break;
  if(c=='\n')
  {
   i2c_parar();
   pantalla_linea();
   pantalla_comienzoDatos();
   continue;
  }
  pantalla_car(c);
 }
 i2c_parar();
}

void pantalla_println(const __FlashStringHelper *s)
{
 pantalla_print(s);
 pantalla_linea();
}

void pantalla_println()
{
 pantalla_linea();
}

// Invierte toda la pantalla
void pantalla_invertir(byte inv)
{
 if(inv) pantalla_cmd(0xA7); else pantalla_cmd(0xA6);
}

// Gira la pantalla
void pantalla_rotar(byte r)
{
 girada=r;
 if(r==0)
 {
  pantalla_cmd(0xA1);
  pantalla_cmd(0xC8);
 }
 else
 {
  pantalla_cmd(0xA0);
  pantalla_cmd(0xC0);
 }
}

